# ============================================================
# AlphaHive — Environment Variables
# Copy this file to .env and fill in your values.
# No paid API keys needed — AlphaHive runs 100% free.
# ============================================================

# --- Ollama (Local LLM) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_SWARM_MODEL=llama3.2:3b
OLLAMA_SPECIALIST_MODEL=llama3.1:8b

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost/alphahive

# --- Cache (Redis) ---
REDIS_URL=redis://localhost:6379

# --- Logging ---
LOG_LEVEL=INFO
